# ============================================================
# Copy to .env and fill in values.
# NEVER commit .env to git!
# ============================================================

# RCON password per server
SURVIVAL_RCON_PASSWORD=change_to_something_secure_and_long

# Add for each extra server:
# CREATIVE_RCON_PASSWORD=another_secure_password

# MC usernames on the whitelist (comma-separated)
MC_WHITELIST=PlayerName1,PlayerName2

# Bridge provisioning secret
# Generate with: openssl rand -hex 32
PROVISIONING_SECRET=generate_with_openssl_rand_hex_32
