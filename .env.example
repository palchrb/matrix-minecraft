# ============================================================
# Kopier til .env og fyll inn verdier.
# ALDRI commit .env til git!
# ============================================================

# RCON-passord per server
SURVIVAL_RCON_PASSWORD=bytt_til_noe_sikkert_og_langt

# Legg til for hver ekstra server:
# CREATIVE_RCON_PASSWORD=annet_sikkert_passord

# MC-brukernavn på whitelisten (kommaseparert)
MC_WHITELIST=SpillerNavn1,SpillerNavn2

# Bridge provisioning secret
# Generer med: openssl rand -hex 32
PROVISIONING_SECRET=generer_med_openssl_rand_hex_32
